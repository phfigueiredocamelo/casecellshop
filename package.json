{
  "name": "casecellshop",
  "private": true,
  "scripts": {
    "build": "nest build api && nest build fake-erp && nest build outbox-worker && nest build order-worker && nest build reconciliation-worker",
    "start:api": "nest start api --watch",
    "start:fake-erp": "nest start fake-erp --watch",
    "start:outbox-worker": "nest start outbox-worker --watch",
    "start:order-worker": "nest start order-worker --watch",
    "start:reconciliation-worker": "nest start reconciliation-worker --watch",
