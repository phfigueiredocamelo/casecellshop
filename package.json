{
  "name": "casecellshop",
  "private": true,
  "scripts": {
    "build": "nest build api && nest build fake-erp && nest build outbox-worker && nest build order-worker && nest build reconciliation-worker",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "prisma:generate": "XDG_CACHE_HOME=.cache prisma generate",
    "prisma:validate": "prisma validate",
    "seed:demo": "ts-node prisma/seed-demo.ts",
    "seed:large": "ts-node prisma/seed-large.ts",
    "k6:products": "k6 run tests/k6/products-load.js",
    "k6:checkout": "k6 run tests/k6/checkout-concurrency.js",
    "k6:idempotency": "k6 run tests/k6/idempotency-retry.js",
    "start:api": "node dist/api/src/main.js",
    "start:api:dev": "nest start api --watch",
    "start:fake-erp": "node dist/fake-erp/src/main.js",
    "start:fake-erp:dev": "nest start fake-erp --watch",
    "start:outbox-worker": "node dist/outbox-worker/src/main.js",
    "start:outbox-worker:dev": "nest start outbox-worker --watch",
    "start:order-worker": "node dist/order-worker/src/main.js",
    "start:order-worker:dev": "nest start order-worker --watch",
    "start:reconciliation-worker": "node dist/reconciliation-worker/src/main.js",
    "start:reconciliation-worker:dev": "nest start reconciliation-worker --watch",
    "start:stack": "node scripts/start-stack.js",
    "test": "jest --config ./tests/jest.integration.json --runInBand",
    "test:integration": "jest --config ./tests/jest.integration.json --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "11.0.0",
    "@nestjs/core": "11.0.0",
    "@nestjs/platform-express": "11.0.0",
    "@prisma/client": "6.0.0",
    "amqplib": "0.10.5",
    "ioredis": "5.4.1",
    "pino": "9.3.2",
    "prom-client": "15.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.0",
    "@nestjs/testing": "11.0.0",
    "@types/jest": "29.5.12",
    "@types/node": "22.10.2",
    "jest": "29.7.0",
    "prisma": "6.0.0",
    "supertest": "7.0.0",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "typescript": "5.7.2"
  }
}
