    "amqplib": "0.10.5",
    "ioredis": "5.4.1",
    "pino": "9.3.2",
    "prom-client": "15.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.0",
    "@nestjs/testing": "11.0.0",
    "@types/jest": "29.5.12",
    "@types/node": "22.10.2",
    "jest": "29.7.0",
    "prisma": "6.0.0",
    "supertest": "7.0.0",
    "ts-jest": "29.2.5",
