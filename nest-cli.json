{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "apps/api",
  "sourceRoot": "apps/api/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "tsconfig.build.json"
  },
  "projects": {
    "api": {
      "type": "application",
      "root": "apps/api",
      "entryFile": "main",
      "sourceRoot": "apps/api/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.build.json"
      }
    },
    "fake-erp": {
      "type": "application",
      "root": "apps/fake-erp",
      "entryFile": "main",
      "sourceRoot": "apps/fake-erp/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.build.json"
      }
    },
    "outbox-worker": {
      "type": "application",
      "root": "apps/outbox-worker",
      "entryFile": "main",
      "sourceRoot": "apps/outbox-worker/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.build.json"
      }
    },
    "order-worker": {
      "type": "application",
      "root": "apps/order-worker",
      "entryFile": "main",
      "sourceRoot": "apps/order-worker/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.build.json"
      }
    },
    "reconciliation-worker": {
      "type": "application",
      "root": "apps/reconciliation-worker",
      "entryFile": "main",
      "sourceRoot": "apps/reconciliation-worker/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.build.json"
      }
    }
  }
}
